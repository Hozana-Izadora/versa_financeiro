# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://financas_app:change_this_app_password@localhost:5432/financas

# Express port (optional, defaults to 3001)
PORT=3001

# JWT — generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_random_64_byte_hex_string
JWT_EXPIRES_IN=15m

# Refresh token lifetime in days (default: 7)
REFRESH_TOKEN_EXPIRES_DAYS=7

# Allowed CORS origin for the frontend (dev only; in prod everything goes through nginx)
CORS_ORIGIN=http://localhost:5173
