# ============================================================
# Copy this file to .env and fill in all values.
# .env is gitignored and must NEVER be committed.
# On the server: chmod 600 .env
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_SUPERUSER_PASSWORD=change_this_superuser_password
POSTGRES_APP_PASSWORD=change_this_app_password

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_random_64_byte_hex_string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# ── Network ──────────────────────────────────────────────────
HTTP_PORT=80

# ── ngrok (opcional, apenas para testes) ─────────────────────
# Obtenha em: https://dashboard.ngrok.com
NGROK_AUTHTOKEN=
